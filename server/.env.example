NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/interviewace?retryWrites=true&w=majority
# Direct URI fallback (required on Windows if querySrv ECONNREFUSED)
MONGODB_URI_DIRECT=mongodb://username:password@shard-host-00.xxxxx.mongodb.net:27017,shard-host-01.xxxxx.mongodb.net:27017,shard-host-02.xxxxx.mongodb.net:27017/interviewace?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=your_openai_api_key_fallback
CLIENT_URL=http://localhost:5173
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
