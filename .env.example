# Environment variables for InterviewAce AI

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/interviewace?retryWrites=true&w=majority

# JWT secret (use a strong random string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# AI API Keys (at least one required for AI features)
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_fallback

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Frontend API URL (for Vercel deployment)
VITE_API_URL=https://your-render-app.onrender.com/api
